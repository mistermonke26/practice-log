<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow LAN / dev HTTP APIs from the kiosk app (tablet → Mac/PC). -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
